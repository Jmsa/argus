{
  "name": "argus-mcp",
  "version": "1.0.0",
  "description": "Argus — Chrome DevTools Protocol MCP server for browser debugging",
  "type": "module",
  "main": "dist/server/index.js",
  "bin": {
    "argus": "dist/server/index.js"
  },
  "scripts": {
    "build:inject": "tsx src/inject/build.ts",
    "build": "npm run build:inject && tsc",
    "dev": "npm run build:inject && tsx src/server/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
