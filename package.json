{
  "name": "@jmsa/argus-mcp",
  "version": "1.1.0",
  "description": "Argus — Chrome DevTools Protocol MCP server for browser debugging",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "chrome",
    "devtools",
    "cdp",
    "browser",
    "debugging",
    "claude"
  ],
  "license": "MIT",
  "type": "module",
  "main": "dist/server/index.js",
  "bin": {
    "argus-mcp": "dist/server/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build:inject": "tsx src/inject/build.ts",
    "build": "npm run clean && npm run build:inject && tsc && mkdir -p dist/domains && cp src/domains/welcome.html dist/domains/",
    "prepare": "npm run build",
    "dev": "npm run build:inject && tsx src/server/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Jmsa/argus.git"
  },
  "homepage": "https://github.com/Jmsa/argus#readme",
  "bugs": {
    "url": "https://github.com/Jmsa/argus/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
